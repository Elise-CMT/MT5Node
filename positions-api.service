[Unit]
Description=Positions API (FastAPI + Redis)
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/positions-api
Environment=REDIS_HOST=127.0.0.1
Environment=REDIS_PORT=6379
Environment=API_PORT=8080
ExecStart=/opt/positions-api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
